                  "const body = pm.response.json();",
                  "pm.environment.set('headVersion', body.version);",
                  "pm.collectionVariables.set('headVersion', body.version);"
                ]
              }
            }
          ]
        },
        {
          "name": "List records for template",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/repos/{{repoName}}/records/basic.yaml",
