                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "08 Sync — Write",
      "description": "Exercise the structured write path. Each request uses {{headVersion}} captured earlier as parent_version; after a successful write, the response's new version is saved back into {{headVersion}} so the next write fast-forwards.",
      "item": [
        {
          "name": "PUT one file (fast-forward)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"parent_version\": \"{{headVersion}}\",\n  \"content_b64\": \"aGVsbG8gZnJvbSBwb3N0bWFuCg==\",\n  \"message\": \"postman: add hello.txt\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/repos/{{repoName}}/files/hello.txt",
              "host": ["{{baseUrl}}"],
              "path": ["api", "repos", "{{repoName}}", "files", "hello.txt"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('new version returned', () => pm.expect(body.version).to.be.a('string').and.not.empty);",
                  "pm.test('version advanced from parent', () => pm.expect(body.version).to.not.eql(pm.variables.get('headVersion')));",
                  "pm.environment.set('headVersion', body.version);",
                  "pm.collectionVariables.set('headVersion', body.version);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST multi-file commit",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"parent_version\": \"{{headVersion}}\",\n  \"changes\": [\n    { \"op\": \"put\", \"path\": \"notes/a.md\", \"content_b64\": \"YWFhCg==\" },\n    { \"op\": \"put\", \"path\": \"notes/b.md\", \"content_b64\": \"YmJiCg==\" }\n  ],\n  \"message\": \"postman: add two notes\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/repos/{{repoName}}/commits",
              "host": ["{{baseUrl}}"],
              "path": ["api", "repos", "{{repoName}}", "commits"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('new version returned', () => pm.expect(body.version).to.be.a('string').and.not.empty);",
                  "pm.environment.set('headVersion', body.version);",
                  "pm.collectionVariables.set('headVersion', body.version);"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT with stale parent (expect 409)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"parent_version\": \"0000000000000000000000000000000000000000\",\n  \"content_b64\": \"c3RhbGUK\",\n  \"message\": \"postman: stale write should conflict\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/repos/{{repoName}}/files/hello.txt",
              "host": ["{{baseUrl}}"],
              "path": ["api", "repos", "{{repoName}}", "files", "hello.txt"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('stale parent is a 4xx', () => pm.expect(pm.response.code).to.be.within(400, 499));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "09 Formidable Records",
      "description": "Formidable-first record query endpoint. The demo repo is scaffolded with a basic.yaml template but no records until this folder PUTs one.",
      "item": [
        {
